{
  "productName": "faces-h",
  "version": "0.1.0",
  "identifier": "com.faces-h.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "shifth",
    "copyright": "Copyright © 2026 shifth",
    "shortDescription": "Local face recognition photo organizer",
    "longDescription": "faces-h organizes your personal photo library by face recognition, entirely on your device. No cloud, no account, no uploads — every photo stays on your drive.",
    "resources": [],
    "externalBin": ["../sidecar/dist/faces-sidecar"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerHooks": "./nsis/hooks.nsi",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/justminime/faces-h/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDMTc2QzJCOTE1MTI5NjMKUldSaktWR1JLMndYWEhuMU9Kb09YYzR4SnRlTzhwNmRmdklCNEhhL0tDVW1UeHU2K0tzQnUyenIK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "faces-h",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'"
    }
  }
}
